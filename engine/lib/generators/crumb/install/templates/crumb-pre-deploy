#!/usr/bin/env bash
set -euo pipefail

source "$(dirname "$0")/crumb-env"

DIRTY=false
if [[ "$KAMAL_VERSION" == *_uncommitted_* ]] || ! git diff --quiet || ! git diff --cached --quiet; then
  if [[ "$DEST" == "production" ]]; then
    echo "Crumb: dirty working tree — aborting production deploy" >&2
    exit 1
  fi
  DIRTY=true
fi

UNPUSHED=false
if git log "@{u}.." --oneline 2>/dev/null | grep -q .; then
  if [[ "$DEST" == "production" ]]; then
    echo "Crumb: unpushed commits — aborting production deploy" >&2
    exit 1
  fi
  UNPUSHED=true
fi

METADATA="{\"dirty\":$DIRTY,\"unpushed\":$UNPUSHED}"
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")

RESPONSE=$(curl -sf -X POST "$CRUMB_API_URL/deploys" \
  -H "Authorization: Bearer $CRUMB_INGEST_SECRET" \
  -H "Content-Type: application/json" \
  -d "{\"sha\":\"$KAMAL_VERSION\",\"branch\":\"$BRANCH\",\"author\":\"$KAMAL_PERFORMER\",\"started_at\":\"$KAMAL_RECORDED_AT\",\"metadata\":$METADATA}" 2>/dev/null) || {
  echo "Crumb: failed to open deploy record — skipping" >&2
  exit 0
}

DEPLOY_ID=$(echo "$RESPONSE" | ruby -rjson -e 'puts JSON.parse($stdin.read)["deploy_id"]' 2>/dev/null) || { echo "Crumb: unexpected response — skipping" >&2; exit 0; }
PREVIOUS_SHA=$(echo "$RESPONSE" | ruby -rjson -e 'puts JSON.parse($stdin.read)["previous_sha"].to_s' 2>/dev/null || echo "")

echo "$DEPLOY_ID $PREVIOUS_SHA" > "/tmp/crumb_${KAMAL_VERSION}.tmp"
